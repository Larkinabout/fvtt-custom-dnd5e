<li class="item custom-dnd5e-item" data-key="{{triggerId}}">
    <div class="item-row">
        <i class="custom-dnd5e-drag fa-solid fa-grip-lines" draggable="true"></i>
        <select name="triggers.{{triggerId}}.event" class="custom-dnd5e-trigger-event">
            {{selectOptions triggerChoices selected=event localize=true}}
        </select>
        <div class="custom-dnd5e-trigger-fields">
            <div class="custom-dnd5e-roll-subtype-group flexrow{{#unless showRollSubtype}} hidden{{/unless}}">
                <div class="form-fields">
                    <select name="triggers.{{triggerId}}.rollSubtype" class="custom-dnd5e-roll-subtype-select">
                        {{selectOptions rollSubtypeChoices selected=rollSubtype}}
                    </select>
                </div>
            </div>
            <div class="custom-dnd5e-counter-trigger-group flexrow{{#unless showCounterSelect}} hidden{{/unless}}">
                <div class="form-fields">
                    <select name="triggers.{{triggerId}}.counterKey" class="custom-dnd5e-counter-select">
                        {{selectOptions counterChoices selected=counterKey}}
                    </select>
                </div>
            </div>
            <div class="custom-dnd5e-condition-trigger-group flexrow{{#unless showConditionSelect}} hidden{{/unless}}">
                <div class="form-fields">
                    <select name="triggers.{{triggerId}}.conditionId" class="custom-dnd5e-condition-select">
                        {{selectOptions conditionChoices selected=conditionId}}
                    </select>
                </div>
            </div>
            <div class="custom-dnd5e-effect-trigger-group flexrow{{#unless showEffectNameInput}} hidden{{/unless}}">
                <div class="form-fields">
                    <input name="triggers.{{triggerId}}.effectName" type="text" value="{{effectName}}"
                        class="custom-dnd5e-effect-name-input"
                        placeholder="{{localize 'CUSTOM_DND5E.form.workflows.trigger.effectName.placeholder'}}">
                </div>
            </div>
            <div class="custom-dnd5e-trigger-condition-group flexrow{{#unless showCondition}} hidden{{/unless}}">
                <div class="form-fields">
                    <select name="triggers.{{triggerId}}.result" class="custom-dnd5e-trigger-result">
                        {{selectOptions conditionChoicesForTrigger selected=result localize=true}}
                    </select>
                    <input name="triggers.{{triggerId}}.value" type="text" value="{{value}}" class="custom-dnd5e-trigger-value{{#unless showValueInput}} hidden{{/unless}}" placeholder="{{localize 'CUSTOM_DND5E.form.workflows.triggerValue.label'}}">
                </div>
            </div>
        </div>
        <div class="item-controls always-visible">
            <button type="button" data-action="deleteRow" class="unbutton control-button item-control always-interactive" data-tooltip="{{localize 'CUSTOM_DND5E.form.button.delete.tooltip'}}" aria-label="{{localize 'CUSTOM_DND5E.form.button.delete.tooltip'}}">
                <i class="fas fa-trash" inert></i>
            </button>
        </div>
    </div>
</li>
