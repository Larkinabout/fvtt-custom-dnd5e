<div class="standard-form">
    <div class="form-group">
        <label class="flex1" style="min-width:80px; max-width:200px;">{{localize "CUSTOM_DND5E.form.workflows.enable"}}</label>
        <div class="form-fields">
            <dnd5e-checkbox id="custom-dnd5e-enabled" name="enabled"{{#if enabled}} checked{{/if}}></dnd5e-checkbox>
        </div>
    </div>
    <nav class="sheet-tabs tabs" style="flex: none;">
        <a class="item{{#if (eq activeTab 'actors')}} active{{/if}}" data-action="tab" data-group="primary" data-tab="actors">
            <span>
                <i class="fa-solid fa-users"></i>
                {{localize "CUSTOM_DND5E.actors"}}
            </span>
        </a>
        <a class="item{{#if (eq activeTab 'items')}} active{{/if}}" data-action="tab" data-group="primary" data-tab="items">
            <span>
                <i class="fa-solid fa-suitcase"></i>
                {{localize "CUSTOM_DND5E.items"}}
            </span>
        </a>
    </nav>
    <hr>
    <div class="standard-form scrollable">
        <section class="tab{{#if (eq activeTab 'actors')}} active{{/if}}" data-group="primary" data-tab="actors">
            <div class="custom-dnd5e-items-sections">
                <div class="items-section card">
                    <div class="items-header header">
                        <h3 class="item-name">{{localize "CUSTOM_DND5E.form.workflows.listTitle"}}</h3>
                    </div>
                    <ol class="item-list unlist custom-dnd5e-list">
                        {{> "modules/custom-dnd5e/templates/workflows/workflows-list.hbs" triggers=actorTriggers}}
                    </ol>
                </div>
                <button type="button" data-action="new" class="gold-button always-interactive" aria-label="{{localize 'CUSTOM_DND5E.form.button.new.label'}}">
                    <i class="fas fa-plus" inert></i>
                </button>
            </div>
        </section>
        <section class="tab{{#if (eq activeTab 'items')}} active{{/if}}" data-group="primary" data-tab="items">
            <div class="custom-dnd5e-items-sections">
                <div class="items-section card">
                    <div class="items-header header">
                        <h3 class="item-name">{{localize "CUSTOM_DND5E.form.workflows.listTitle"}}</h3>
                    </div>
                    <ol class="item-list unlist custom-dnd5e-list">
                        {{> "modules/custom-dnd5e/templates/workflows/workflows-list.hbs" triggers=itemTriggers}}
                    </ol>
                </div>
                <button type="button" data-action="new" class="gold-button always-interactive" aria-label="{{localize 'CUSTOM_DND5E.form.button.new.label'}}">
                    <i class="fas fa-plus" inert></i>
                </button>
            </div>
        </section>
    </div>
    <footer class="form-footer" data-application-part="footer">
        <button type="submit" class="save-button">
            <i class="fas fa-solid fa-floppy-disk"></i>{{localize "CUSTOM_DND5E.form.button.save.label"}}
        </button>
    </footer>
</div>
