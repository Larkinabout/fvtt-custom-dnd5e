{{#each triggers}}
<li class="item custom-dnd5e-item" data-key="{{#if key}}{{key}}{{else}}{{customDnd5eRandomId}}{{/if}}">
    <div class="item-row">
        <i class="custom-dnd5e-drag fa-solid fa-grip-lines" draggable="true"></i>
        <div class="custom-dnd5e-col-group flexcol">
            <div class="form-group">
                <label class="flex1" style="min-width:80px; max-width:100px;">{{localize "CUSTOM_DND5E.trigger"}}</label>
                <div class="form-fields">
                    <select id="custom-dnd5e-trigger" name="trigger">
                        {{selectOptions ../selects.trigger.choices selected=trigger localize=true}}
                    </select>
                </div>
            </div>
            <div class="form-group{{#unless (customDnd5eShowTriggerValue trigger)}} hidden{{/unless}}">
                <label class="flex1" style="min-width:80px; max-width:100px;">{{localize "CUSTOM_DND5E.triggerValue"}}</label>
                <div class="form-fields">
                    <select id="custom-dnd5e-trigger-operator" name="triggerOperator">
                        {{selectOptions ../selects.triggerOperator.choices selected=triggerOperator localize=true}}
                    </select>
                    <input id="custom-dnd5e-trigger-value" name="triggerValue" type="text" value="{{triggerValue}}">
                </div>
            </div>
            <div class="form-group">
                <label class="flex1" style="min-width:80px; max-width:100px;">{{localize "CUSTOM_DND5E.action"}}</label>
                <div class="form-fields">
                    <select id="custom-dnd5e-action" name="action">
                        {{selectOptions ../selects.action.choices selected=action localize=true}}
                    </select>
                </div>
            </div>
            <div class="form-group{{#unless (customDnd5eShowActionValue action)}} hidden{{/unless}}">
                <label class="flex1" style="min-width:80px; max-width:100px;">{{localize "CUSTOM_DND5E.actionValue"}}</label>
                <div class="form-fields">
                    <input id="custom-dnd5e-action-value" name="actionValue" type="number" value="{{actionValue}}">
                </div>
            </div>
            <div class="form-group{{#unless (customDnd5eEq action "macro")}} hidden{{/unless}}">
                <label class="flex1" style="min-width:80px; max-width:100px;">{{localize "CUSTOM_DND5E.macro"}}</label>
                <div class="form-fields custom-dnd5e-macro-drop">
                    <div class="custom-dnd5e-drop-area custom-dnd5e-macro-field flex1{{#unless macroName}} hidden{{/unless}}">
                        <span class="custom-dnd5e-macro-name">{{macroName}}</span>
                        <button type="button" data-action="clearMacro" class="unbutton control-button" data-tooltip="{{localize 'CUSTOM_DND5E.form.counters.triggers.macro.clear'}}" aria-label="{{localize 'CUSTOM_DND5E.form.counters.triggers.macro.clear'}}">
                            <i class="fa-solid fa-trash" inert></i>
                        </button>
                    </div>
                    <div class="custom-dnd5e-drop-area drop-area flex1{{#if macroName}} hidden{{/if}}">{{localize "CUSTOM_DND5E.dropHint.macro"}}</div>
                    <input type="hidden" name="macroUuid" value="{{macroUuid}}">
                </div>
            </div>
        </div>
        <div class="item-controls always-visible">
            <button type="button" data-action="delete" class="unbutton control-button item-control always-interactive" data-tooltip="{{localize 'CUSTOM_DND5E.form.button.delete.tooltip'}}" aria-label="{{localize 'CUSTOM_DND5E.form.button.delete.tooltip'}}">
                <i class="fas fa-trash" inert></i>
            </button>
            <input id="custom-dnd5e-delete" name="delete" type="hidden" value="false">
        </div>
    </div>
</li>
{{/each}}